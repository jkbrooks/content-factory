# OpenAI — used by all agents for content generation
OPENAI_API_KEY=sk-...

# Beehiiv — one publication ID per cluster you're running
# Find these in your Beehiiv dashboard under Settings > Publications
BEEHIIV_API_KEY=...
BEEHIIV_PUB_CLUSTER_A=pub_...
BEEHIIV_PUB_CLUSTER_B=pub_...
BEEHIIV_PUB_CLUSTER_C=pub_...
BEEHIIV_PUB_CLUSTER_D=pub_...

# Paperclip — set automatically when you create an agent in the UI
# PAPERCLIP_API_KEY=...
# PAPERCLIP_BASE_URL=http://localhost:3100

# Optional: social posting
# X_API_KEY=...
# X_API_SECRET=...
# X_ACCESS_TOKEN=...
# X_ACCESS_SECRET=...

# Optional: ElevenLabs TTS for audio versions
# ELEVENLABS_API_KEY=...
